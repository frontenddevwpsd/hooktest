# Normalize line endings to LF on commit, leave working files alone
* text=auto
 
# Explicitly mark text files
*.php     text
*.js      text
*.jsx     text
*.ts      text
*.tsx     text
*.css     text
*.scss    text
*.less    text
*.html    text
*.htm     text
*.xml     text
*.svg     text
*.json    text
*.yml     text
*.yaml    text
*.md      text
*.txt     text
*.sh      text
*.ini     text
*.env     text
*.lock    text
.htaccess text
.htpasswd text
robots.txt text
 
# Windows scripts keep CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf
 
# Binary files (never touch these)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.bmp     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.mp3     binary
*.mp4     binary
*.mov     binary
*.webm    binary
*.zip     binary
*.tar     binary
*.gz      binary
*.rar     binary
*.7z      binary
*.pdf     binary
*.doc     binary
*.docx    binary
*.xls     binary
*.xlsx    binary
*.psd     binary
*.ai      binary