* text=auto eol=lf

# ===== Source code =====
*.php     text eol=lf diff=php
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.vue     text eol=lf
*.css     text eol=lf diff=css
*.scss    text eol=lf diff=css
*.sass    text eol=lf
*.less    text eol=lf
*.html    text eol=lf diff=html
*.htm     text eol=lf
*.xml     text eol=lf
*.svg     text eol=lf
 
# ===== Config / data files =====
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
*.ini        text eol=lf
*.env        text eol=lf
*.lock       text eol=lf
.htaccess    text eol=lf
.htpasswd    text eol=lf
robots.txt   text eol=lf
 
# ===== Docs =====
*.md         text eol=lf diff=markdown
*.txt        text eol=lf
LICENSE      text eol=lf
README       text eol=lf
CHANGELOG    text eol=lf
 
# ===== Shell / build scripts =====
*.sh         text eol=lf
*.bash       text eol=lf
Makefile     text eol=lf
 
# ===== Windows-specific scripts (keep CRLF) =====
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf
 
# ===== Images (binary) =====
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.webp       binary
*.bmp        binary
*.tiff       binary
*.psd        binary
*.ai         binary
 
# ===== Fonts (binary) =====
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.eot        binary
 
# ===== Media (binary) =====
*.mp3        binary
*.mp4        binary
*.mov        binary
*.avi        binary
*.webm       binary
*.ogg        binary
*.wav        binary
*.flv        binary
 
# ===== Archives (binary) =====
*.zip        binary
*.tar        binary
*.gz         binary
*.tgz        binary
*.rar        binary
*.7z         binary
 
# ===== Documents (binary) =====
*.pdf        binary
*.doc        binary
*.docx       binary
*.xls        binary
*.xlsx       binary
*.ppt        binary
*.pptx       binary
 
# ===== Files to exclude from `git archive` / plugin-theme ZIPs =====
# Useful if you distribute via `git archive` for WP.org or releases
/.github            export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.editorconfig      export-ignore
/.vscode            export-ignore
/.idea              export-ignore
/tests              export-ignore
/node_modules       export-ignore
/bin                export-ignore
/docs               export-ignore
phpunit.xml         export-ignore
phpunit.xml.dist    export-ignore
phpcs.xml           export-ignore
phpcs.xml.dist      export-ignore
.phpcs.xml.dist     export-ignore
composer.json       export-ignore
composer.lock       export-ignore
package.json        export-ignore
package-lock.json   export-ignore
yarn.lock           export-ignore
webpack.config.js   export-ignore
gulpfile.js         export-ignore
.eslintrc           export-ignore
.prettierrc         export-ignore
.stylelintrc        export-ignore
README.md           export-ignore
CHANGELOG.md        export-ignore
CONTRIBUTING.md     export-ignore